@page
@model StudentRegistrationSystem.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white text-center py-4">
                    <i class="bi bi-person-plus fs-1"></i>
                    <h3 class="mb-0 mt-2">Create Account</h3>
                    <p class="mb-0 opacity-75">Join the Student Registration System</p>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.FullName" class="form-label">
                                    <i class="bi bi-person-badge me-1"></i>Full Name
                                </label>
                                <input asp-for="Input.FullName" class="form-control" placeholder="John Doe" />
                                <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.Username" class="form-label">
                                    <i class="bi bi-at me-1"></i>Username
                                </label>
                                <input asp-for="Input.Username" class="form-control" placeholder="johndoe" />
                                <span asp-validation-for="Input.Username" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label">
                                <i class="bi bi-envelope me-1"></i>Email Address
                            </label>
                            <input asp-for="Input.Email" class="form-control" placeholder="john@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.Password" class="form-label">
                                    <i class="bi bi-key me-1"></i>Password
                                </label>
                                <input asp-for="Input.Password" type="password" class="form-control" placeholder="Min 6 characters" />
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.ConfirmPassword" class="form-label">
                                    <i class="bi bi-key-fill me-1"></i>Confirm Password
                                </label>
                                <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Re-enter password" />
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-3">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-person-plus me-2"></i>Create Account
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light text-center py-3">
                    <span class="text-muted">Already have an account?</span>
                    <a asp-page="/Account/Login" class="text-primary fw-bold text-decoration-none">Sign in here</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
