@page
@model StudentRegistrationSystem.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="auth-card">
                    <div class="auth-header">
                        <div class="auth-icon" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">
                            <i class="bi bi-person-plus"></i>
                        </div>
                        <h2>Create Account</h2>
                        <p>Join the Student Registration System</p>
                    </div>
                    <div class="auth-body">
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                            {
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.FullName" class="form-label">Full Name</label>
                                    <input asp-for="Input.FullName" class="form-control" placeholder="John Doe" />
                                    <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.Username" class="form-label">Username</label>
                                    <input asp-for="Input.Username" class="form-control" placeholder="johndoe" />
                                    <span asp-validation-for="Input.Username" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.Email" class="form-label">Email Address</label>
                                <input asp-for="Input.Email" class="form-control" placeholder="john@example.com" />
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.Password" class="form-label">Password</label>
                                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="Min 6 characters" />
                                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
                                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Re-enter password" />
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="d-grid mt-3">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="bi bi-person-plus me-2"></i>Create Account
                                </button>
                            </div>
                        </form>
                    </div>
                    <div class="auth-footer">
                        <span>Already have an account?</span>
                        <a asp-page="/Account/Login">Sign in here</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
