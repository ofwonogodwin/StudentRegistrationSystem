@page
@model StudentRegistrationSystem.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow border-danger">
                <div class="card-body py-5">
                    <i class="bi bi-shield-x text-danger" style="font-size: 5rem;"></i>
                    <h2 class="mt-3 text-danger">Access Denied</h2>
                    <p class="text-muted mb-4">
                        Sorry, you don't have permission to access this page.
                        Please contact the administrator if you believe this is an error.
                    </p>
                    <div class="d-flex gap-2 justify-content-center">
                        <a asp-page="/Students/Index" class="btn btn-primary">
                            <i class="bi bi-house me-2"></i>Go to Home
                        </a>
                        <a asp-page="/Account/Login" class="btn btn-outline-secondary">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
