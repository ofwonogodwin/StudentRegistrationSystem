@page
@model StudentRegistrationSystem.Pages.Students.IndexModel
@{
    ViewData["Title"] = "Students";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="page-header mb-4">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h2><i class="bi bi-mortarboard-fill me-2"></i>Student Management</h2>
                <p>View, search, and manage all registered students in the system.</p>
            </div>
            <div class="col-md-4 text-md-end">
                <a asp-page="Create" class="btn btn-light btn-lg">
                    <i class="bi bi-person-plus-fill me-2"></i>Register New Student
                </a>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="stats-card">
                <div class="stats-number">@Model.TotalStudents</div>
                <div class="stats-label"><i class="bi bi-people me-1"></i>Total Students</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="stats-card" style="background: linear-gradient(135deg, #06d6a0 0%, #05c090 100%);">
                <div class="stats-number">@Model.FilteredCount</div>
                <div class="stats-label"><i class="bi bi-funnel me-1"></i>Showing</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="stats-card" style="background: linear-gradient(135deg, #ffd166 0%, #f0c040 100%); color: #333;">
                <div class="stats-number">@Model.AvailableCourses.Count</div>
                <div class="stats-label"><i class="bi bi-book me-1"></i>Courses</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="stats-card" style="background: linear-gradient(135deg, #ef476f 0%, #dc3545 100%);">
                <div class="stats-number">5</div>
                <div class="stats-label"><i class="bi bi-calendar me-1"></i>Year Levels</div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="search-box">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label"><i class="bi bi-search me-1"></i>Search</label>
                <input type="text" asp-for="SearchTerm" class="form-control search-input" 
                       placeholder="Search by name, registration no, email..." />
            </div>
            <div class="col-md-2">
                <label class="form-label"><i class="bi bi-book me-1"></i>Course</label>
                <select asp-for="CourseFilter" class="form-select">
                    <option value="">All Courses</option>
                    @foreach (var course in Model.AvailableCourses)
                    {
                        <option value="@course">@course</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label"><i class="bi bi-calendar3 me-1"></i>Year</label>
                <select asp-for="YearFilter" class="form-select">
                    <option value="">All Years</option>
                    <option value="1">Year 1</option>
                    <option value="2">Year 2</option>
                    <option value="3">Year 3</option>
                    <option value="4">Year 4</option>
                    <option value="5">Year 5</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label"><i class="bi bi-sort-alpha-down me-1"></i>Sort By</label>
                <select asp-for="SortOrder" class="form-select">
                    <option value="name_asc">Name (A-Z)</option>
                    <option value="name_desc">Name (Z-A)</option>
                    <option value="reg_asc">Reg No (Asc)</option>
                    <option value="reg_desc">Reg No (Desc)</option>
                    <option value="course_asc">Course (A-Z)</option>
                    <option value="year_asc">Year (1-5)</option>
                    <option value="year_desc">Year (5-1)</option>
                    <option value="date_desc">Newest First</option>
                    <option value="date_asc">Oldest First</option>
                </select>
            </div>
            <div class="col-md-2">
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-funnel-fill me-1"></i>Apply
                    </button>
                    <a asp-page="Index" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-x-circle me-1"></i>Clear
                    </a>
                </div>
            </div>
        </form>
    </div>

    <!-- Active Filters Display -->
    @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.CourseFilter) || Model.YearFilter.HasValue)
    {
        <div class="mb-3">
            <span class="text-muted me-2">Active filters:</span>
            @if (!string.IsNullOrEmpty(Model.SearchTerm))
            {
                <span class="badge bg-primary me-1">
                    <i class="bi bi-search me-1"></i>Search: @Model.SearchTerm
                </span>
            }
            @if (!string.IsNullOrEmpty(Model.CourseFilter))
            {
                <span class="badge bg-info me-1">
                    <i class="bi bi-book me-1"></i>Course: @Model.CourseFilter
                </span>
            }
            @if (Model.YearFilter.HasValue)
            {
                <span class="badge bg-warning text-dark me-1">
                    <i class="bi bi-calendar me-1"></i>Year: @Model.YearFilter
                </span>
            }
        </div>
    }

    <!-- Students Table -->
    @if (Model.Students.Any())
    {
        <div class="card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h5 class="mb-0">
                    <i class="bi bi-table me-2"></i>Registered Students
                </h5>
                <span class="badge bg-primary fs-6">@Model.FilteredCount of @Model.TotalStudents</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Full Name</th>
                                <th>Registration No.</th>
                                <th>Email</th>
                                <th>Course</th>
                                <th>Year</th>
                                <th>Registered</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var rowNum = 1; }
                            @foreach (var student in Model.Students)
                            {
                                <tr>
                                    <td>@rowNum</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="user-avatar me-2" style="background: linear-gradient(135deg, #4361ee 0%, #7209b7 100%); width: 36px; height: 36px;">
                                                <i class="bi bi-person text-white"></i>
                                            </div>
                                            <div>
                                                <strong>@student.FullName</strong>
                                                @if (!string.IsNullOrEmpty(student.PhoneNumber))
                                                {
                                                    <br/><small class="text-muted"><i class="bi bi-telephone me-1"></i>@student.PhoneNumber</small>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td><code class="text-primary">@student.RegistrationNumber</code></td>
                                    <td>
                                        <a href="mailto:@student.Email" class="text-decoration-none">
                                            <i class="bi bi-envelope me-1"></i>@student.Email
                                        </a>
                                    </td>
                                    <td>@student.Course</td>
                                    <td>
                                        <span class="badge badge-year">Year @student.YearOfStudy</span>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            <i class="bi bi-calendar-event me-1"></i>@student.CreatedAt.ToString("dd MMM yyyy")
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        <div class="action-buttons">
                                            <a asp-page="./Edit" asp-route-id="@student.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            <a asp-page="./Delete" asp-route-id="@student.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash-fill"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                rowNum++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body empty-state">
                <i class="bi bi-inbox"></i>
                <h4>No Students Found</h4>
                @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.CourseFilter) || Model.YearFilter.HasValue)
                {
                    <p class="text-muted">No students match your current filters. Try adjusting your search criteria.</p>
                    <a asp-page="Index" class="btn btn-outline-primary">
                        <i class="bi bi-x-circle me-2"></i>Clear All Filters
                    </a>
                }
                else
                {
                    <p class="text-muted">There are no students registered in the system yet.</p>
                    <a asp-page="Create" class="btn btn-primary">
                        <i class="bi bi-person-plus-fill me-2"></i>Register First Student
                    </a>
                }
            </div>
        </div>
    }
</div>