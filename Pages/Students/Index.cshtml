@page
@model StudentRegistrationSystem.Pages.Students.IndexModel
@{
    ViewData["Title"] = "Students";
}

<div class="page-header-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1>Student Management</h1>
                <p class="lead">View, search, and manage all registered students in the system.</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a asp-page="Create" class="btn btn-primary btn-lg">
                    <i class="bi bi-person-plus-fill me-2"></i>Register Student
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <!-- Statistics Cards -->
    <div class="dashboard-stats">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="bi bi-people"></i>
            </div>
            <div class="stat-content">
                <div class="stat-number">@Model.TotalStudents</div>
                <div class="stat-label">Total Students</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(6, 182, 212, 0.1); color: var(--accent);">
                <i class="bi bi-funnel"></i>
            </div>
            <div class="stat-content">
                <div class="stat-number">@Model.FilteredCount</div>
                <div class="stat-label">Currently Showing</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">
                <i class="bi bi-book"></i>
            </div>
            <div class="stat-content">
                <div class="stat-number">@Model.AvailableCourses.Count</div>
                <div class="stat-label">Available Courses</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">
                <i class="bi bi-calendar"></i>
            </div>
            <div class="stat-content">
                <div class="stat-number">5</div>
                <div class="stat-label">Year Levels</div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-search me-2"></i>Search & Filter</h5>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-lg-4 col-md-6">
                    <label class="form-label">Search</label>
                    <input type="text" asp-for="SearchTerm" class="form-control"
                           placeholder="Name, registration no, email..." />
                </div>
                <div class="col-lg-2 col-md-6">
                    <label class="form-label">Course</label>
                    <select asp-for="CourseFilter" class="form-control">
                        <option value="">All Courses</option>
                        @foreach (var course in Model.AvailableCourses)
                        {
                            <option value="@course">@course</option>
                        }
                    </select>
                </div>
                <div class="col-lg-2 col-md-4">
                    <label class="form-label">Year</label>
                    <select asp-for="YearFilter" class="form-control">
                        <option value="">All Years</option>
                        <option value="1">Year 1</option>
                        <option value="2">Year 2</option>
                        <option value="3">Year 3</option>
                        <option value="4">Year 4</option>
                        <option value="5">Year 5</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-4">
                    <label class="form-label">Sort By</label>
                    <select asp-for="SortOrder" class="form-control">
                        <option value="name_asc">Name (A-Z)</option>
                        <option value="name_desc">Name (Z-A)</option>
                        <option value="reg_asc">Reg No (Asc)</option>
                        <option value="reg_desc">Reg No (Desc)</option>
                        <option value="course_asc">Course (A-Z)</option>
                        <option value="year_asc">Year (1-5)</option>
                        <option value="year_desc">Year (5-1)</option>
                        <option value="date_desc">Newest First</option>
                        <option value="date_asc">Oldest First</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-4">
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-funnel-fill me-1"></i>Apply Filters
                        </button>
                    </div>
                </div>
            </form>
            @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.CourseFilter) ||
                Model.YearFilter.HasValue)
            {
                <div class="mt-3 pt-3 border-top">
                    <span class="text-muted me-2">Active filters:</span>
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <span class="badge bg-primary me-1">Search: @Model.SearchTerm</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.CourseFilter))
                    {
                        <span class="badge bg-info me-1">Course: @Model.CourseFilter</span>
                    }
                    @if (Model.YearFilter.HasValue)
                    {
                        <span class="badge bg-warning text-dark me-1">Year: @Model.YearFilter</span>
                    }
                    <a asp-page="Index" class="btn btn-outline-secondary btn-sm ms-2">
                        <i class="bi bi-x-circle me-1"></i>Clear All
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Students Table -->
    @if (Model.Students.Any())
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-table me-2"></i>Registered Students</h5>
                <span class="badge bg-primary">@Model.FilteredCount of @Model.TotalStudents students</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>Student</th>
                                <th>Registration No.</th>
                                <th>Email</th>
                                <th>Course</th>
                                <th>Year</th>
                                <th>Registered</th>
                                <th class="text-center" style="width: 120px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var rowNum = 1;
                            }
                            @foreach (var student in Model.Students)
                            {
                                <tr>
                                    <td class="text-muted">@rowNum</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar me-3">
                                                @student.FullName.Substring(0, 1).ToUpper()
                                            </div>
                                            <div>
                                                <strong>@student.FullName</strong>
                                                @if (!string.IsNullOrEmpty(student.PhoneNumber))
                                                {
                                                    <br />
                                                    <small class="text-muted">@student.PhoneNumber</small>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td><code>@student.RegistrationNumber</code></td>
                                    <td>
                                        <a href="mailto:@student.Email" class="text-decoration-none">@student.Email</a>
                                    </td>
                                    <td>@student.Course</td>
                                    <td>
                                        <span class="badge bg-primary-subtle text-primary">Year @student.YearOfStudy</span>
                                    </td>
                                    <td>
                                        <small class="text-muted">@student.CreatedAt.ToString("dd MMM yyyy")</small>
                                    </td>
                                    <td class="text-center">
                                        <a asp-page="./Edit" asp-route-id="@student.Id"
                                           class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-page="./Delete" asp-route-id="@student.Id"
                                           class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                                rowNum++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <div class="mb-4">
                    <i class="bi bi-inbox display-1 text-muted"></i>
                </div>
                <h4>No Students Found</h4>
                @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.CourseFilter) ||
                    Model.YearFilter.HasValue)
                {
                    <p class="text-muted mb-4">No students match your current filters. Try adjusting your search criteria.</p>
                    <a asp-page="Index" class="btn btn-outline-primary">
                        <i class="bi bi-x-circle me-2"></i>Clear All Filters
                    </a>
                }
                else
                {
                    <p class="text-muted mb-4">There are no students registered in the system yet.</p>
                    <a asp-page="Create" class="btn btn-primary">
                        <i class="bi bi-person-plus-fill me-2"></i>Register First Student
                    </a>
                }
            </div>
        </div>
    }
</div>
    </div>