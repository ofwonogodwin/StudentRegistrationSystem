@page
@model StudentRegistrationSystem.Pages.Students.DeleteModel
@{
    ViewData["Title"] = "Delete Student";
}

<div class="page-header-section" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);">
    <div class="container">
        <h1><i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Student</h1>
        <p class="lead">Review the student information before confirming deletion.</p>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="bi bi-person-x me-2"></i>Confirm Deletion</h5>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning d-flex align-items-center" role="alert">
                        <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
                        <div>
                            <strong>Warning!</strong> This action is permanent and cannot be undone.
                            All data associated with this student will be permanently removed.
                        </div>
                    </div>

                    <!-- Student Information Card -->
                    <div class="card bg-light mb-4">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <h6 class="section-title">Personal Information</h6>
                                    <dl class="row mb-0">
                                        <dt class="col-sm-5">Full Name:</dt>
                                        <dd class="col-sm-7"><strong>@Model.Student.FullName</strong></dd>

                                        <dt class="col-sm-5">Email:</dt>
                                        <dd class="col-sm-7">@Model.Student.Email</dd>

                                        @if (!string.IsNullOrEmpty(Model.Student.PhoneNumber))
                                        {
                                            <dt class="col-sm-5">Phone:</dt>
                                            <dd class="col-sm-7">@Model.Student.PhoneNumber</dd>
                                        }
                                    </dl>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="section-title">Academic Information</h6>
                                    <dl class="row mb-0">
                                        <dt class="col-sm-5">Reg. Number:</dt>
                                        <dd class="col-sm-7"><code>@Model.Student.RegistrationNumber</code></dd>

                                        <dt class="col-sm-5">Course:</dt>
                                        <dd class="col-sm-7">@Model.Student.Course</dd>

                                        <dt class="col-sm-5">Year:</dt>
                                        <dd class="col-sm-7"><span class="badge bg-primary-subtle text-primary">Year
                                            @Model.Student.YearOfStudy</span></dd>
                                        </dl>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <form method="post">
                            <input type="hidden" asp-for="Student.Id" />
                            <div class="d-flex justify-content-between">
                                <a asp-page="./Index" class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-left me-2"></i>Cancel
                                </a>
                                <button type="submit" class="btn btn-danger btn-lg">
                                    <i class="bi bi-trash-fill me-2"></i>Yes, Delete Student
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>