@page
@model StudentRegistrationSystem.Pages.Students.EditModel
@{
    ViewData["Title"] = "Edit Student";
}

<div class="page-header-section">
    <div class="container">
        <h1>Edit Student Information</h1>
        <p class="lead">Update the student's details below.</p>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-clipboard-data me-2"></i>Student Information</h5>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="Student.Id" />
                        <input type="hidden" asp-for="Student.CreatedAt" />

                        <!-- Personal Information Section -->
                        <h6 class="section-title">Personal Information</h6>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="Student.FullName" class="form-label">Full Name <span
                                    class="text-danger">*</span></label>
                                    <input asp-for="Student.FullName" class="form-control" placeholder="Enter full name" />
                                    <span asp-validation-for="Student.FullName" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="Student.Gender" class="form-label">Gender</label>
                                    <select asp-for="Student.Gender" class="form-control">
                                        <option value="">Select Gender</option>
                                        <option value="Male">Male</option>
                                        <option value="Female">Female</option>
                                        <option value="Other">Other</option>
                                    </select>
                                    <span asp-validation-for="Student.Gender" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Student.DateOfBirth" class="form-label">Date of Birth</label>
                                    <input asp-for="Student.DateOfBirth" type="date" class="form-control" />
                                    <span asp-validation-for="Student.DateOfBirth" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Student.PhoneNumber" class="form-label">Phone Number</label>
                                    <input asp-for="Student.PhoneNumber" class="form-control" placeholder="+256700000000" />
                                    <span asp-validation-for="Student.PhoneNumber" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- Contact Information Section -->
                            <h6 class="section-title mt-4">Contact Information</h6>

                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <label asp-for="Student.Email" class="form-label">Email Address <span
                                        class="text-danger">*</span></label>
                                        <input asp-for="Student.Email" type="email" class="form-control"
                                               placeholder="student@example.com" />
                                        <span asp-validation-for="Student.Email" class="text-danger small"></span>
                                    </div>
                                </div>

                                <!-- Academic Information Section -->
                                <h6 class="section-title mt-4">Academic Information</h6>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Student.RegistrationNumber" class="form-label">Registration Number <span
                                            class="text-danger">*</span></label>
                                            <input asp-for="Student.RegistrationNumber" class="form-control"
                                                   placeholder="e.g., REG/2024/001" />
                                            <span asp-validation-for="Student.RegistrationNumber" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label asp-for="Student.YearOfStudy" class="form-label">Year of Study <span
                                                class="text-danger">*</span></label>
                                                <select asp-for="Student.YearOfStudy" class="form-control">
                                                    <option value="">Select Year</option>
                                                    <option value="1">Year 1</option>
                                                    <option value="2">Year 2</option>
                                                    <option value="3">Year 3</option>
                                                    <option value="4">Year 4</option>
                                                    <option value="5">Year 5</option>
                                                </select>
                                                <span asp-validation-for="Student.YearOfStudy" class="text-danger small"></span>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label asp-for="Student.Course" class="form-label">Course / Program <span
                                                    class="text-danger">*</span></label>
                                                    <input asp-for="Student.Course" class="form-control"
                                                           placeholder="e.g., Bachelor of Software Engineering" />
                                                    <span asp-validation-for="Student.Course" class="text-danger small"></span>
                                                </div>
                                            </div>

                                            <hr class="my-4" />

                                            <div class="d-flex justify-content-between">
                                                <a asp-page="Index" class="btn btn-outline-secondary">
                                                    <i class="bi bi-arrow-left me-2"></i>Back to List
                                                </a>
                                                <button type="submit" class="btn btn-primary btn-lg">
                                                    <i class="bi bi-check-circle me-2"></i>Save Changes
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @section Scripts {
                        @{
                            await Html.RenderPartialAsync("_ValidationScriptsPartial");
                        }
                    }